{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...all].ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "buildCommand": "npx nx build frontend --configuration=production",
  "outputDirectory": "dist/frontend/browser"
}
