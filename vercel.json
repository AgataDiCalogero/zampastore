{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/[...all].ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "buildCommand": "npx nx build frontend --configuration=production",
  "outputDirectory": "dist/frontend/browser"
}
